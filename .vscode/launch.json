// A launch configuration that compiles the extension and then opens it inside a new window
// Use IntelliSense to learn about possible attributes.
// Hover to view descriptions of existing attributes.
// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Extension — nRF",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}",
				"--disable-workspace-trust",
				"--disable-extension",
				"saoudrizwan.claude-dev",
				"--disable-extension",
				"saoudrizwan.cline-nightly",
				"${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js"
			],
			"preLaunchTask": "${defaultBuildTask}",
			"envFile": "${workspaceFolder}/.env",
			"env": {
				"IS_DEV": "true",
				"IOT_PLATFORM": "nrf",
				"DEV_WORKSPACE_FOLDER": "${workspaceFolder}",
				"CLINE_ENVIRONMENT": "production",
				// Dev override: resolve DOWNLOADED (proprietary) bits — incl. the 10 CRA bits — from the
				// Adsum-Backend/kbits/ tree on disk, so F5 has the same edit-and-run loop as bundled bits.
				// Gated on IS_DEV; esbuild dead-codes it out of any shipped VSIX. Adjust the path if the
				// Adsum-Backend checkout lives elsewhere relative to this repo.
				"ADSUM_KBIT_LOCAL": "${workspaceFolder}/../Adsum-Backend/kbits"
			}
		},
		{
			"name": "Run Extension — nRF (registry kbits · pre-release)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}",
				"--disable-workspace-trust",
				"--disable-extension",
				"saoudrizwan.claude-dev",
				"--disable-extension",
				"saoudrizwan.cline-nightly",
				"${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js"
			],
			"preLaunchTask": "${defaultBuildTask}",
			"envFile": "${workspaceFolder}/.env",
			"env": {
				"IS_DEV": "true",
				"IOT_PLATFORM": "nrf",
				"DEV_WORKSPACE_FOLDER": "${workspaceFolder}",
				"CLINE_ENVIRONMENT": "production"
				// PRE-RELEASE GROUND-TRUTH: deliberately NO ADSUM_KBIT_LOCAL, so DOWNLOADED (proprietary)
				// bits resolve from the PROD registry (https://api.adsumnetworks.com/v1/kbits) exactly like a
				// released VSIX. Use this to verify the real release path (e.g. the demo-debug-hci kbit) before
				// publishing the VSIX. The default "Run Extension — nRF" still uses the on-disk kbits for fast iteration.
			}
		},
		{
			"name": "Run Extension — ESP",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}",
				"--disable-workspace-trust",
				"--disable-extension",
				"saoudrizwan.claude-dev",
				"--disable-extension",
				"saoudrizwan.cline-nightly",
				"${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js"
			],
			"preLaunchTask": "${defaultBuildTask}",
			"envFile": "${workspaceFolder}/.env",
			"env": {
				"IS_DEV": "true",
				"IOT_PLATFORM": "esp",
				"DEV_WORKSPACE_FOLDER": "${workspaceFolder}",
				"CLINE_ENVIRONMENT": "production",
				// Dev override: resolve DOWNLOADED (proprietary) bits — incl. the 10 CRA bits — from the
				// Adsum-Backend/kbits/ tree on disk (see the nRF config above). Gated on IS_DEV; dead-coded
				// out of any shipped VSIX by esbuild.
				"ADSUM_KBIT_LOCAL": "${workspaceFolder}/../Adsum-Backend/kbits"
			}
		},
		{
			"name": "Run Extension (production)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}",
				"--disable-workspace-trust",
				"--disable-extension",
				"saoudrizwan.claude-dev", // Avoid conflicts with installed Cline
				"--disable-extension",
				"saoudrizwan.cline-nightly", // Avoid conflicts with installed Cline Nightly
				"${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js"
			],
			"skipFiles": [
				"**/node_modules/**"
			],
			"preLaunchTask": "${defaultBuildTask}",
			"envFile": "${workspaceFolder}/.env",
			"env": {
				"IS_DEV": "true",
				"DEV_WORKSPACE_FOLDER": "${workspaceFolder}",
				"CLINE_ENVIRONMENT": "production",
				"ADSUM_KBIT_LOCAL": "${workspaceFolder}/../Adsum-Backend/kbits"
			}
		},
		{
			"name": "Run Extension (staging)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}",
				"--disable-workspace-trust",
				"--disable-extension",
				"saoudrizwan.claude-dev", // Avoid conflicts with installed Cline
				"--disable-extension",
				"saoudrizwan.cline-nightly", // Avoid conflicts with installed Cline Nightly
				"${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js"
			],
			"preLaunchTask": "${defaultBuildTask}",
			"envFile": "${workspaceFolder}/.env",
			"env": {
				"IS_DEV": "true",
				"DEV_WORKSPACE_FOLDER": "${workspaceFolder}",
				"CLINE_ENVIRONMENT": "staging",
				"ADSUM_KBIT_LOCAL": "${workspaceFolder}/../Adsum-Backend/kbits"
			}
		},
		{
			"name": "Run Extension (local)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}",
				"--disable-workspace-trust",
				"--disable-extension",
				"saoudrizwan.claude-dev", // Avoid conflicts with installed Cline
				"--disable-extension",
				"saoudrizwan.cline-nightly", // Avoid conflicts with installed Cline Nightly
				"${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js"
			],
			"preLaunchTask": "${defaultBuildTask}",
			"envFile": "${workspaceFolder}/.env",
			"env": {
				"IS_DEV": "true",
				"DEV_WORKSPACE_FOLDER": "${workspaceFolder}",
				"CLINE_ENVIRONMENT": "local",
				"ADSUM_KBIT_LOCAL": "${workspaceFolder}/../Adsum-Backend/kbits"
			}
		},
		{
			"name": "Run Extension (Fresh Install Mode)",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${execPath}",
			"args": [
				// Fresh, isolated VS Code data dir (wiped each launch by the clean-tmp-user preLaunchTask)
				// gives true fresh-install state. NOTE: do NOT add --profile-temp here — the ephemeral
				// profile breaks the debugger's reattach on window reload (close folder / reload window),
				// so the extension wouldn't come back without killing the whole debug instance.
				"--user-data-dir=${workspaceFolder}/dist/tmp/user",
				"--sync=off",
				"--disable-extension",
				"saoudrizwan.claude-dev", // Avoid conflicts with installed Cline
				"--disable-extension",
				"saoudrizwan.cline-nightly", // Avoid conflicts with installed Cline Nightly
				"--extensionDevelopmentPath=${workspaceFolder}",
				"${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js"
			],
			"preLaunchTask": "clean-tmp-user",
			"internalConsoleOptions": "openOnSessionStart",
			"postDebugTask": "stop",
			"envFile": "${workspaceFolder}/.env",
			"env": {
				"IS_DEV": "true",
				"TEMP_PROFILE": "true",
				"DEV_WORKSPACE_FOLDER": "${workspaceFolder}",
				"CLINE_ENVIRONMENT": "production",
				"ADSUM_KBIT_LOCAL": "${workspaceFolder}/../Adsum-Backend/kbits"
			}
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debug Test Standalone Core Api Server (test:sca-server)",
			"skipFiles": [
				"<node_internals>/**"
			],
			"sourceMaps": true,
			"resolveSourceMapLocations": [
				"${workspaceFolder}/**",
				"!**/node_modules/**"
			],
			"cwd": "${workspaceFolder}",
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js",
				"${workspaceFolder}/dist-standalone/**/*.js"
			],
			"preLaunchTask": "compile-standalone",
			"runtimeExecutable": "npx",
			"runtimeArgs": [
				"tsx"
			],
			"program": "scripts/test-standalone-core-api-server.ts",
			"envFile": "${workspaceFolder}/.env",
			"env": {
				"PROTOBUS_PORT": "26040",
				"HOSTBRIDGE_PORT": "26041",
				"WORKSPACE_DIR": "${workspaceFolder}",
				"E2E_TEST": "true",
				"CLINE_ENVIRONMENT": "local"
			},
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen"
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debug Current Test File",
			"skipFiles": [
				"<node_internals>/**"
			],
			"sourceMaps": true,
			"resolveSourceMapLocations": [
				"${workspaceFolder}/**",
				"!**/node_modules/**"
			],
			"cwd": "${workspaceFolder}",
			"runtimeExecutable": "npx",
			"runtimeArgs": [
				"mocha"
			],
			"args": [
				"--require",
				"ts-node/register",
				"--require",
				"source-map-support/register",
				"--require",
				"./src/test/requires.ts",
				"--exit",
				"${file}"
			],
			"envFile": "${workspaceFolder}/.env",
			"env": {
				"TS_NODE_PROJECT": "./tsconfig.unit-test.json",
				"NODE_ENV": "test",
				"IS_DEV": "true",
				"CLINE_ENVIRONMENT": "local"
			},
			"console": "integratedTerminal",
			"internalConsoleOptions": "openOnSessionStart"
		},
		{
			"name": "Open Storybook",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "npm",
			"runtimeArgs": [
				"run",
				"storybook"
			],
			"cwd": "${workspaceFolder}/webview-ui",
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"serverReadyAction": {
				"pattern": "Local:.*http://localhost:([0-9]+)",
				"uriFormat": "http://localhost:%s",
				"action": "openExternally"
			},
			"env": {
				"IS_DEV": "true"
			}
		}
	]
}
